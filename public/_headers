# Cloudflare Pages headers (copied to out/ on next export, like _redirects).
# Safe{Wallet} fetches manifest.json + the icon cross-origin to load pinka as a
# Safe App, so they need permissive CORS. Required by the Safe Apps SDK listing
# criteria — see funding/SAFE-APP-LISTING.md in bizops-automation-private.
/manifest.json
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET
  Access-Control-Allow-Headers: X-Requested-With, content-type, Authorization

/pinka-icon.svg
  Access-Control-Allow-Origin: *

# Version manifest polled by the in-app "Ažuriraj" banner to detect a newer
# deploy. Must never be cached, or clients keep comparing against a stale commit
# and the update prompt never fires (or fires forever). CF edge is purged per
# deploy anyway; this also stops the browser from serving its own cached copy.
/version.json
  Cache-Control: no-cache, no-store, must-revalidate
