# pinka.finance app — okolina
# Backend = domovina-api Supabase (self-hosted, api.domovina.ai).

# Public site URL (metadata, OG).
NEXT_PUBLIC_SITE_URL="https://app.pinka.finance"

# Supabase (domovina-api). Anon key je javno-siguran; sve je RLS-gated.
NEXT_PUBLIC_SUPABASE_URL="https://api.domovina.ai"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Certilia / NIAS eID OIDC proxy (dijeljen s domovina.ai). Klijent ovdje odrađuje
# OIDC flow i dobije idToken koji `certilia` edge fn verificira → Supabase sesija.
# VAŽNO: origin ove aplikacije mora biti u ALLOWED_ORIGINS certilia-servera.
NEXT_PUBLIC_CERTILIA_SERVER_URL="https://certilia.domovina.ai"

# Payment rail (mpt.domovina.ai) — koristi se za trajni SEPA QR po kampanji
# (GET /api/intents/campaign-qr). Origin ove aplikacije mora biti u ALLOWED_ORIGINS rail-a.
NEXT_PUBLIC_RAIL_URL="https://mpt.domovina.ai"
